PORT=3000
HOST=127.0.0.1
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=notepad

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# Comma-separated emails that should be treated as administrators.
ADMIN_EMAILS=admin@example.com

# Set false to block new signups.
SIGNUP_ENABLED=true

# Cap
CAP_ENDPOINT=https://cap.bmov.co
CAP_SITE_KEY=1234567890
CAP_SECRET=cap-secret
